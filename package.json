		"@typescript-eslint/parser": "^5.27.0",
		"dotenv-cli": "^6.0.0",
		"eslint": "^8.16.0",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-svelte3": "^4.0.0",
		"jsonwebtoken": "^8.5.1",
		"prettier": "^2.6.2",
